# App
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sliik_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Apple Sign-In
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Payment redirect URLs (sent to payment provider, mobile app handles deep link)
PAYMENT_SUCCESS_URL=sliik://payment/success
PAYMENT_CANCEL_URL=sliik://payment/cancel

# Payouts (platform's commission percentage on each booking; provider keeps the rest)
PLATFORM_COMMISSION_PERCENT=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Uploads
MAX_UPLOAD_SIZE_MB=5

# Mail (SMTP - Gmail for now, swappable to any SMTP provider)
# MAIL_PASSWORD is a Gmail App Password (16 chars), NOT the account password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM_NAME=Sliik
MAIL_FROM_ADDRESS=your_gmail_address@gmail.com

# Password reset (OTP)
PASSWORD_RESET_CODE_EXPIRY_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60

# Rate limiting (applied to password-reset endpoints): max THROTTLE_LIMIT requests per THROTTLE_TTL_SECONDS per IP
THROTTLE_TTL_SECONDS=900
THROTTLE_LIMIT=3
